#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

CHECK_MARK="✅"
CROSS_MARK="❌"
SEARCH_ICON="🔍"
SHIELD_ICON="🛡️"
SPARKLES="✨"
ROCKET="🚀"

echo -e "\n${PURPLE}${SPARKLES} AppleBlox Unquarantine Tool ${SPARKLES}${NC}\n"

print_status() {
    echo -e "${BLUE}${SEARCH_ICON} $1${NC}"
}

print_success() {
    echo -e "${GREEN}${CHECK_MARK} $1${NC}"
}

print_error() {
    echo -e "${RED}${CROSS_MARK} $1${NC}"
}

launch_app() {
    print_status "Launching AppleBlox..."
    if open "$1"; then
        print_success "AppleBlox launched successfully!"
    else
        print_error "Failed to launch AppleBlox"
        exit 1
    fi
}

DMG_PATH=""
for dmg in "$HOME/Downloads"/AppleBlox-*.dmg "$HOME/Desktop"/AppleBlox-*.dmg; do
    if [ -f "$dmg" ]; then
        DMG_PATH="$dmg"
        break
    fi
done

if [ -n "$DMG_PATH" ]; then
    print_status "Found installer image: $(basename "$DMG_PATH")"
    print_status "Removing quarantine from installer image..."
    if xattr -cr "$DMG_PATH" 2>/dev/null; then
        print_success "Installer image unquarantined!"
        echo -e "\n${CYAN}${SHIELD_ICON} You can now open the DMG, then double-click the PKG inside to install AppleBlox.${NC}\n"
    else
        print_error "Failed to remove quarantine from installer image"
        echo -e "${YELLOW}Try: sudo xattr -cr \"$DMG_PATH\"${NC}"
    fi
fi

PKG_PATH=""
for pkg in "$HOME/Downloads"/AppleBlox-*.pkg "$HOME/Desktop"/AppleBlox-*.pkg; do
    if [ -f "$pkg" ]; then
        PKG_PATH="$pkg"
        break
    fi
done

if [ -z "$PKG_PATH" ] && [ -f "/Volumes/AppleBlox/Install AppleBlox.pkg" ]; then
    PKG_PATH="/Volumes/AppleBlox/Install AppleBlox.pkg"
fi

if [ -n "$PKG_PATH" ]; then
    print_status "Found installer: $(basename "$PKG_PATH")"
    print_status "Removing quarantine from installer..."
    if xattr -cr "$PKG_PATH" 2>/dev/null; then
        print_success "Installer unquarantined!"
        echo -e "\n${CYAN}${SHIELD_ICON} You can now open the installer to install AppleBlox.${NC}"
        echo -e "${CYAN}   Double-click the PKG file in Finder to continue.${NC}\n"
    else
        print_error "Failed to remove quarantine from installer"
        echo -e "${YELLOW}Try: sudo xattr -cr \"$PKG_PATH\"${NC}"
    fi
fi

print_status "Searching for AppleBlox installation..."

LOCATIONS=(
    "/Applications/AppleBlox.app"
    "$HOME/Applications/AppleBlox.app"
)

APP_PATH=""
for loc in "${LOCATIONS[@]}"; do
    if [ -d "$loc" ]; then
        APP_PATH="$loc"
        break
    fi
done

if [ -z "$APP_PATH" ]; then
    if [ -n "$PKG_PATH" ] || [ -n "$DMG_PATH" ]; then
        echo -e "${CYAN}Install AppleBlox using the PKG installer, then run this script again to launch it.${NC}\n"
        exit 0
    fi
    print_error "AppleBlox not found. Download the installer from https://appleblox.com"
    exit 1
fi

print_status "Verifying bundle identifier..."
BUNDLE_ID=$(mdls -name kMDItemCFBundleIdentifier -r "$APP_PATH" 2>/dev/null)

if [ "$BUNDLE_ID" != "ch.origaming.appleblox" ]; then
    print_error "Bundle ID mismatch or couldn't be verified"
    print_error "Expected: ch.origaming.appleblox"
    print_error "Found: $BUNDLE_ID"
    exit 1
fi

print_status "Removing quarantine attribute..."
if xattr -cr "$APP_PATH" 2>/dev/null; then
    print_success "Quarantine attribute removed successfully!"
    echo -e "\n${CYAN}${SHIELD_ICON} AppleBlox is now ready to use${NC}"
    echo -e "\n${CYAN}${ROCKET} Starting AppleBlox...${NC}"
    launch_app "$APP_PATH"
else
    print_error "Failed to remove quarantine attribute"
    echo -e "\n${YELLOW}Try running the script with sudo:${NC}"
    echo -e "sudo bash -c \"\$(curl -fsSL https://appleblox.com/helper)\""
    exit 1
fi

echo -e "\n${GREEN}${SPARKLES} All done! ${SPARKLES}${NC}\n"
